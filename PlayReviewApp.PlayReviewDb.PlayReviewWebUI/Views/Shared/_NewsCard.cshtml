@model News


<div class="col-sm-12 col-md-4 my-2 ">
    <div class="card" style="width: 18rem;">
        <a asp-controller="Product" asp-action="Get" asp-route-id="@Model?.NewsId"
           class="text-decoration-none text-body">

            <div class="card-header text-center d-flex justify-content-center align-items-center" style="height: 75px;">
                @Model.Title
            </div>

            <img src="@Model?.ImageUrl" class="card-img-top" alt="...">

            <div class="card-body">
                <div class="card-text">
                    <div class="text-danger text-center lead p-2 rounded-2">
                    </div>
                </div>
                <p class="card-text">@Model?.Content</p>
                <div class="d-flex justify-content-center">
                    <div class="btn btn-group">
                        <i class="fa-solid fa-arrow-right"> </i>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>
